        aimBtn.BackgroundColor3=Color3.fromRGB(0,170,0)
    else
        aimBtn.Text="AIM: OFF"
        aimBtn.BackgroundColor3=Color3.fromRGB(170,0,0)
    end
end)

scanAll()

print("FULL SNAP AIM + ESP + TIMER READY")
