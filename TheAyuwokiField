local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

local ESP_TAG = "_esp_item"
local ESP_ENABLED = true
local AIM_ENABLED = false

local MAX_DISTANCE = 400
local AYUWOKI_WARN_DISTANCE = 80

local ITEM_MAP = {
["Tomar Vendas"] = true,
["Tomar Camara"] = true,
["Tomar Mapa"] = true,
["Tomar Maра"] = true,
["Tomar Escoba"] = true,
["Tomar Barra energetica"] = true,
["Tomar Soda"] = true
}

local tracked = {}

local function getRoot()
    local char = player.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
end

-- ================= ESP ITEM =================
local function isValidItemPrompt(prompt)
    if not prompt or not prompt.Enabled then return false end
    local text = prompt.ActionText

    if ITEM_MAP[text] then return true end
    if string.find(string.lower(text),"tomar") and not string.find(string.lower(text),"puerta") then
        return true
    end

    return false
end

local function createESP(part,textName)
    if not ESP_ENABLED then return end
    if not part or not part:IsA("BasePart") then return end
    if part:FindFirstChild(ESP_TAG) then return end

    local bill = Instance.new("BillboardGui",part)
    bill.Name = ESP_TAG
    bill.Adornee = part
    bill.Size = UDim2.new(0,200,0,50)
    bill.AlwaysOnTop = true
    bill.StudsOffset = Vector3.new(0,2,0)
    bill.MaxDistance = MAX_DISTANCE

    local txt = Instance.new("TextLabel",bill)
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = Color3.fromRGB(0,255,0)
    txt.TextStrokeTransparency = 0
    txt.TextScaled = true
    txt.Text = textName

    tracked[part] = true
end

local function removeESP(part)
    if part and part:FindFirstChild(ESP_TAG) then
        part[ESP_TAG]:Destroy()
    end
    tracked[part] = nil
end

local function clearAllESP()
    for part,_ in pairs(tracked) do
        removeESP(part)
    end
end

local function getPrompt(part)
    for _,v in pairs(part:GetDescendants()) do
        if v:IsA("ProximityPrompt") and isValidItemPrompt(v) then
            return v
        end
    end
end

local function scanAll()
    for _,v in pairs(Workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and isValidItemPrompt(v) then
            local part=v.Parent
            if part and part:IsA("BasePart") then
                createESP(part,v.ActionText)
            end
        end
    end
end

Workspace.DescendantAdded:Connect(function(v)
    if not ESP_ENABLED then return end

    if v:IsA("ProximityPrompt") then
        task.wait(0.1)
        if isValidItemPrompt(v) then
            local part=v.Parent
            if part and part:IsA("BasePart") then
                createESP(part,v.ActionText)
            end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(2)

        if not ESP_ENABLED then continue end
        local root=getRoot()
        if not root then continue end    

        for part,_ in pairs(tracked) do    
            if not part or not part.Parent then    
                removeESP(part)    
            else    
                local prompt=getPrompt(part)    

                if not prompt then    
                    removeESP(part)    
                else    
                    local dist=(root.Position-part.Position).Magnitude    

                    if dist>MAX_DISTANCE then    
                        removeESP(part)    
                    else    
                        local gui=part:FindFirstChild(ESP_TAG)    
                        if gui then    
                            local label=gui:FindFirstChildOfClass("TextLabel")    
                            if label then    
                                label.Text=prompt.ActionText.." ["..math.floor(dist).."m]"    
                            end    
                        end    
                    end    
                end    
            end    
        end
    end
end)

-- ================= AYUWOKI ESP =================
local ayuwokiList = {}

local function addAyuwoki(v)
    ayuwokiList[v] = true

    if not v:FindFirstChild("_ayuwoki") then
        local h = Instance.new("Highlight")
        h.Name = "_ayuwoki"
        h.Adornee = v
        h.FillColor = Color3.fromRGB(255,0,0)
        h.OutlineColor = Color3.fromRGB(255,0,0)
        h.FillTransparency = 0.4
        h.OutlineTransparency = 0
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Parent = v
    end
end

-- scan sẵn
for _,v in pairs(Workspace:GetDescendants()) do
    if v:IsA("Model") and string.find(string.lower(v.Name),"ayuwoki") then
        addAyuwoki(v)
    end
end

-- spawn sau
Workspace.DescendantAdded:Connect(function(v)
    if v:IsA("Model") and string.find(string.lower(v.Name),"ayuwoki") then
        addAyuwoki(v)
    end
end)

-- ================= AIM SNAP =================
RunService.RenderStepped:Connect(function()
    if not AIM_ENABLED then return end

    local root = getRoot()
    if not root then return end

    local closest=nil
    local dist=math.huge

    for m,_ in pairs(ayuwokiList) do
        if m and m.Parent then
            local hrp=m:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d=(root.Position-hrp.Position).Magnitude
                if d<dist then
                    dist=d
                    closest=hrp
                end
            end
        end
    end

    if closest then
        -- SNAP CAMERA
        camera.CFrame = CFrame.new(camera.CFrame.Position, closest.Position)

        -- SNAP PLAYER
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame =
                CFrame.new(char.HumanoidRootPart.Position, closest.Position)
        end
    end
end)

-- ================= GUI =================
local gui = Instance.new("ScreenGui",player:WaitForChild("PlayerGui"))

local warn = Instance.new("TextLabel", gui)
warn.Size = UDim2.new(0,300,0,60)
warn.Position = UDim2.new(0.5,-150,0,120)
warn.TextScaled = true
warn.BackgroundTransparency = 1
warn.TextColor3 = Color3.fromRGB(255,0,0)
warn.Visible = false

task.spawn(function()
    while true do
        task.wait(0.5)

        local root=getRoot()
        if not root then continue end

        local near=false
        for m,_ in pairs(ayuwokiList) do
            if m and m.Parent then
                local hrp=m:FindFirstChild("HumanoidRootPart")
                if hrp and (root.Position-hrp.Position).Magnitude<AYUWOKI_WARN_DISTANCE then
                    near=true
                end
            end
        end

        warn.Visible=near
        warn.Text="⚠ AYUWOKI NEAR ⚠"
    end
end)

-- TIMER
local values = ReplicatedStorage:WaitForChild("Values")
local timer = values:WaitForChild("Timer")
local day = values:WaitForChild("DayTheme")

local label = Instance.new("TextLabel", gui)
label.Size = UDim2.new(0,260,0,60)
label.Position = UDim2.new(0.5,-130,0,50)
label.TextScaled = true
label.BackgroundTransparency = 0.3
label.TextColor3 = Color3.new(1,1,1)

local function update()
    local state = (day.Value == 0) and "Night" or "Morning"
    label.Text = state.." : "..timer.Value.."s"
end

update()
timer:GetPropertyChangedSignal("Value"):Connect(update)
day:GetPropertyChangedSignal("Value"):Connect(update)

-- BUTTON ESP
local btn = Instance.new("TextButton", gui)
btn.Size = UDim2.new(0,120,0,40)
btn.Position = UDim2.new(0,20,0,100)
btn.Text = "ESP: ON"
btn.BackgroundColor3 = Color3.fromRGB(0,170,0)

btn.MouseButton1Click:Connect(function()
    ESP_ENABLED = not ESP_ENABLED
    if ESP_ENABLED then
        btn.Text="ESP: ON"
        btn.BackgroundColor3=Color3.fromRGB(0,170,0)
        scanAll()
    else
        btn.Text="ESP: OFF"
        btn.BackgroundColor3=Color3.fromRGB(170,0,0)
        clearAllESP()
    end
end)

